/**
 * Motivational category mapping based on thetruthperspective.org framework.
 */
function _news_extractor_get_motivation_category($motivation) {
  $motivation_map = _news_extractor_get_motivation_map();
  $key = strtolower(trim($motivation));
  return $motivation_map[$key] ?? 'Other';
}

/**
 * Helper function to build AI prompt for social scientist perspective.
 */
function _news_extractor_build_ai_prompt($article_title, $article_text) {
  $allowed_motivations = "Ambition, Competitive spirit, Righteousness, Moral outrage, Loyalty, Pride, Determination, Fear, Greed, Power, Control, Revenge, Justice, Self-preservation, Recognition, Legacy, Influence, Security, Freedom, Unity, Professional pride, Duty, Curiosity, Enthusiasm, Wariness, Anxiety, Self-respect, Obligation, Indignation";

  $allowed_metrics = "Presidential Approval Rating, Congressional Approval Rating, Trust in Government Index, Government Effectiveness Score, Transparency Index, Bills Passed Per Session, Bipartisan Legislation Rate, Committee Productivity, Filibuster Usage Rate, Executive Order Frequency, Voter Turnout Rate, Voter Registration Rate, Electoral Competitiveness, Campaign Finance Totals, Lobbying Expenditures, Federal Judicial Confirmation Rate, Government Shutdown Days, Federal Employee Satisfaction, Congressional Ethics Violations, Polarization Index, GDP Growth Rate, Unemployment Rate, Inflation Rate (CPI), Federal Funds Rate, Labor Force Participation Rate, National Debt, Federal Budget Deficit/Surplus, Debt-to-GDP Ratio, Tax Revenue Growth, Government Spending Growth, Trade Balance, Current Account Balance, Dollar Index (DXY), Manufacturing Output, Productivity Growth, Median Household Income, Poverty Rate, Income Inequality (Gini Coefficient), Consumer Confidence Index, Housing Price Index";

  return "As a social scientist, analyze this article in the context of key performance metrics for the United States.\n\n" .
         "Instructions:\n" .
         "1. Identify each entity (person, organization, institution) mentioned in the article\n" .
         "2. For each entity, select their top 2-3 motivations from the allowed list\n" .
         "3. Choose the SINGLE most relevant US performance metric this article impacts from the allowed metrics list\n" .
         "4. Provide credibility score (0-100, 100=perfect trust, 0=no credibility)\n" .
         "5. Provide bias rating (0=Extreme Left, 25=Lean Left, 50=Center, 75=Lean Right, 100=Extreme Right)\n" .
         "6. Provide bias analysis (two lines explaining the rating)\n" .
         "7. Provide article sentiment score (0-100, 100=most positive, 0=most negative)\n" .
         "8. Provide analysis of how this affects that metric\n\n" .
         "IMPORTANT: Use ONLY motivations from this list: $allowed_motivations\n\n" .
         "IMPORTANT: Choose ONLY ONE metric from this list: $allowed_metrics\n\n" .
         "Format your response EXACTLY as follows using basic HTML:\n\n" .
         "<p><strong>Entities mentioned:</strong><br>\n" .
         "- Entity Name: Motivation1, Motivation2<br>\n" .
         "- Entity Name: Motivation1, Motivation2, Motivation3</p>\n\n" .
         "<p><strong>Key metric:</strong> [Select ONE from allowed metrics list]</p>\n\n" .
         "<p><strong>Credibility Score:</strong> [0-100]</p>\n\n" .
         "<p><strong>Bias Rating:</strong> [0-100]</p>\n\n" .
         "<p><strong>Bias Analysis:</strong><br>\n" .
         "- [First line explaining the bias rating]<br>\n" .
         "- [Second line explaining the bias rating]</p>\n\n" .
         "<p><strong>Article Sentiment Score:</strong> [0-100]</p>\n\n" .
         "<p>As a social scientist, I analyze that [your detailed analysis of how this article impacts the key metric].</p>\n\n" .
         "Article Title: " . $article_title . "\n\n" .
         "Article Text: " . $article_text;
}

/**
 * Extract entities, motivations, and metrics from the AI summary (now with HTML).
 */
function _news_extractor_extract_tags_from_summary($ai_summary) {
  $entities = [];
  $motivations = [];
  $metrics = [];

  // Strip HTML for parsing, but preserve structure
  $text_content = strip_tags($ai_summary);

  // Extract entity-motivation pairings: "- Entity Name: Motivation1, Motivation2, Motivation3"
  if (preg_match('/Entities mentioned:(.*?)(?:Key metric:|$)/is', $text_content, $matches)) {
    foreach (preg_split('/\r?\n/', $matches[1]) as $line) {
      if (preg_match('/-\s*(.+?):\s*(.+)/', $line, $m)) {
        $entity_name = trim($m[1]);
        $entity_motivations = array_map('trim', explode(',', $m[2]));
        $entities[] = $entity_name;
        $motivations = array_merge($motivations, $entity_motivations);
      }
    }
  }

  // Key metric: single line after "Key metric:"
  if (preg_match('/Key metric:\s*(.+)/i', $text_content, $matches)) {
    $metrics[] = trim($matches[1]);
  }

  // Remove duplicates
  $entities = array_unique($entities);
  $motivations = array_unique($motivations);

  return [
    'entities' => $entities,
    'motivations' => $motivations,
    'metrics' => $metrics,
  ];
}

/**
 * Extract structured motivation data from AI summary for JSON field (handles HTML).
 */
function _news_extractor_extract_structured_data($motivation_analysis) {
  $data = [
    'entities' => [],
    'motivations' => [],
    'metrics' => [],
    'credibility_score' => null,
    'bias_rating' => null,
    'bias_analysis' => [],
    'sentiment_score' => null
  ];

  // Strip HTML for parsing
  $text_content = strip_tags($motivation_analysis);

  // Extract entities and their motivations
  if (preg_match('/Entities mentioned:(.*?)(?:Key metric:|$)/is', $text_content, $matches)) {
    foreach (preg_split('/\r?\n/', $matches[1]) as $line) {
      if (preg_match('/-\s*(.+?):\s*(.+)/', $line, $m)) {
        $entity = trim($m[1]);
        $motivations_text = trim($m[2]);
        $motivations = array_map('trim', explode(',', $motivations_text));
        
        $data['entities'][] = [
          'name' => $entity,
          'motivations' => $motivations
        ];
        
        // Also collect unique motivations
        foreach ($motivations as $motivation) {
          if (!empty($motivation) && !in_array($motivation, $data['motivations'])) {
            $data['motivations'][] = $motivation;
          }
        }
      }
    }
  }

  // Extract key metric
  if (preg_match('/Key metric:\s*(.+)/i', $text_content, $matches)) {
    $data['metrics'][] = trim($matches[1]);
  }

  // Extract credibility score
  if (preg_match('/Credibility Score:\s*(\d+)/i', $text_content, $matches)) {
    $data['credibility_score'] = (int)$matches[1];
  }

  // Extract bias rating
  if (preg_match('/Bias Rating:\s*(\d+)/i', $text_content, $matches)) {
    $data['bias_rating'] = (int)$matches[1];
  }

  // Extract bias analysis lines
  if (preg_match('/Bias Analysis:(.*?)(?:Article Sentiment Score:|$)/is', $text_content, $matches)) {
    foreach (preg_split('/\r?\n/', $matches[1]) as $line) {
      $line = trim($line);
      if (preg_match('/^-\s*(.+)/', $line, $m)) {
        $data['bias_analysis'][] = trim($m[1]);
      }
    }
  }

  // Extract sentiment score
  if (preg_match('/Article Sentiment Score:\s*(\d+)/i', $text_content, $matches)) {
    $data['sentiment_score'] = (int)$matches[1];
  }

  return $data;
}

/**
 * Post-process article node to fetch and set external image URL from Diffbot.
 */
function news_extractor_postprocess_article_image(Node $node) {
  // Only process article nodes with an original URL.
  if ($node->bundle() !== 'article' || !$node->hasField('field_original_url')) {
    return;
  }

  $original_url = $node->get('field_original_url')->uri ?? '';
  if (empty($original_url)) {
    return;
  }

  // Get Diffbot token from config (set this in your module config).
  $diffbot_token = news_extractor_get_diffbot_token();
  if (empty($diffbot_token)) {
    \Drupal::logger('news_extractor')->error('Diffbot token not set in configuration.');
    return;
  }

  $api_url = 'https://api.diffbot.com/v3/article?token=' . urlencode($diffbot_token) . '&url=' . urlencode($original_url);

  try {
    $response = \Drupal::httpClient()->get($api_url, ['timeout' => 10]);
    $data = json_decode($response->getBody(), TRUE);

    // Check for images in the Diffbot response.
    if (!empty($data['objects'][0]['images']) && is_array($data['objects'][0]['images'])) {
      $first_image = $data['objects'][0]['images'][0]['url'] ?? '';
      if (!empty($first_image) && filter_var($first_image, FILTER_VALIDATE_URL)) {
        // Set the image URL in the node's field_external_image_url.
        if ($node->hasField('field_external_image_url')) {
          $node->set('field_external_image_url', [
            'uri' => $first_image,
            'title' => $node->getTitle(),
          ]);
          $node->save();
          \Drupal::logger('news_extractor')->info('Set external image URL for node @nid: @url', [
            '@nid' => $node->id(),
            '@url' => $first_image,
          ]);
        }
      }
    }
  } catch (\Exception $e) {
    \Drupal::logger('news_extractor')->error('Error fetching Diffbot image for node @nid: @msg', [
      '@nid' => $node->id(),
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Helper to get the Diffbot API token from config.
 *
 * @return string
 *   The Diffbot API token, or an empty string if not set.
 */
function news_extractor_get_diffbot_token() {
  return \Drupal::config('news_extractor.settings')->get('diffbot_token') ?: '';
}

/**
 * Linkify entity and motivation terms in the motivation analysis.
 */
function news_extractor_linkify_summary_tags($summary, array $tags) {
  foreach ($tags as $tag) {
    $term_name = $tag->getName();
    $term_url = \Drupal\Core\Url::fromRoute('entity.taxonomy_term.canonical', ['taxonomy_term' => $tag->id()])->toString();
    
    // Create the link HTML
    $link_html = '<a href="' . $term_url . '">' . $term_name . '</a>';
    
    // Replace exact matches (case-insensitive, whole words only)
    // Avoid replacing text that's already inside HTML tags or links
    $pattern = '/\b' . preg_quote($term_name, '/') . '\b(?![^<]*>)(?![^<]*<\/a>)/i';
    
    // Replace ALL occurrences, not just the first one
    $summary = preg_replace($pattern, $link_html, $summary);
  }
  
  return $summary;
}

/**
 * Enhanced linkification that handles case mismatches.
 */
function news_extractor_linkify_summary_tags_enhanced($summary, array $tags) {
  // Create a mapping of lowercase term names to actual terms
  $term_map = [];
  foreach ($tags as $tag) {
    $term_name = $tag->getName();
    $key = strtolower($term_name);
    if (!isset($term_map[$key])) {
      $term_map[$key] = [
        'term' => $tag,
        'name' => $term_name,
        'url' => \Drupal\Core\Url::fromRoute('entity.taxonomy_term.canonical', ['taxonomy_term' => $tag->id()])->toString()
      ];
    }
  }
  
  // Find all potential matches in the text
  foreach ($term_map as $key => $data) {
    $term_name = $data['name'];
    $term_url = $data['url'];
    $link_html = '<a href="' . $term_url . '">' . $term_name . '</a>';
    
    // Create multiple patterns to catch different capitalizations
    $patterns = [
      '/\b' . preg_quote($term_name, '/') . '\b(?![^<]*>)(?![^<]*<\/a>)/i', // Original case
      '/\b' . preg_quote(ucfirst(strtolower($term_name)), '/') . '\b(?![^<]*>)(?![^<]*<\/a>)/', // Title case
      '/\b' . preg_quote(strtolower($term_name), '/') . '\b(?![^<]*>)(?![^<]*<\/a>)/', // Lowercase
      '/\b' . preg_quote(strtoupper($term_name), '/') . '\b(?![^<]*>)(?![^<]*<\/a>)/', // Uppercase
    ];
    
    foreach ($patterns as $pattern) {
      $summary = preg_replace($pattern, $link_html, $summary);
    }
  }
  
  return $summary;
}

/**
 * Update existing articles with new AI analysis fields.
 */
function news_extractor_update_existing_articles_with_new_fields() {
  $batch_size = 10;
  $processed = 0;
  
  // Find articles that have AI summary but missing new fields
  $query = \Drupal::entityQuery('node')
    ->condition('type', 'article')
    ->condition('field_ai_summary.value', '', '<>')
    ->accessCheck(FALSE);
    
  // Add condition to find articles missing any of the new fields
  $or_group = $query->orConditionGroup()
    ->condition('field_credibility_score.value', '', '=')
    ->condition('field_bias_rating.value', '', '=')
    ->condition('field_bias_analysis.value', '', '=')
    ->condition('field_article_sentiment_score.value', '', '=');
  
  $query->condition($or_group);
  $query->range(0, $batch_size);
  
  $nids = $query->execute();
  
  if (empty($nids)) {
    \Drupal::logger('news_extractor')->info('No articles found that need updating with new fields.');
    return;
  }
  
  $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
  
  foreach ($nodes as $node) {
    try {
      // Get existing AI summary
      $ai_summary = $node->get('field_ai_summary')->value;
      
      if (empty($ai_summary)) {
        continue;
      }
      
      // Extract structured data from existing AI summary
      $structured_data = _news_extractor_extract_structured_data($ai_summary);
      
      // Update motivation_data field with new structure
      if ($node->hasField('field_motivation_data')) {
        $node->set('field_motivation_data', json_encode($structured_data));
      }
      
      // Populate individual score fields
      if ($node->hasField('field_credibility_score') && !is_null($structured_data['credibility_score'])) {
        $node->set('field_credibility_score', (string)$structured_data['credibility_score']);
      }
      
      if ($node->hasField('field_bias_rating') && !is_null($structured_data['bias_rating'])) {
        $node->set('field_bias_rating', (string)$structured_data['bias_rating']);
      }
      
      if ($node->hasField('field_bias_analysis') && !empty($structured_data['bias_analysis'])) {
        $node->set('field_bias_analysis', implode("\n", $structured_data['bias_analysis']));
      }
      
      if ($node->hasField('field_article_sentiment_score') && !is_null($structured_data['sentiment_score'])) {
        $node->set('field_article_sentiment_score', (string)$structured_data['sentiment_score']);
      }
      
      $node->save();
      $processed++;
      
      \Drupal::logger('news_extractor')->info('Updated article @nid (@title) with new analysis fields', [
        '@nid' => $node->id(),
        '@title' => $node->getTitle(),
      ]);
      
    } catch (\Exception $e) {
      \Drupal::logger('news_extractor')->error('Error updating article @nid: @message', [
        '@nid' => $node->id(),
        '@message' => $e->getMessage(),
      ]);
    }
  }
  
  \Drupal::logger('news_extractor')->info('Updated @count articles with new analysis fields. Run again if more articles need processing.', [
    '@count' => $processed,
  ]);
}

/**
 * Re-generate AI analysis for existing articles using new prompt format.
 */
function news_extractor_regenerate_ai_analysis_for_existing_articles() {
  $batch_size = 5; // Smaller batch for AI processing
  $processed = 0;
  
  // Find articles with body content but missing new analysis fields
  $query = \Drupal::entityQuery('node')
    ->condition('type', 'article')
    ->condition('body.value', '', '<>')
    ->accessCheck(FALSE);
    
  // Add condition for articles missing new fields or old format
  $or_group = $query->orConditionGroup()
    ->condition('field_credibility_score.value', '', '=')
    ->condition('field_bias_rating.value', '', '=')
    ->condition('field_article_sentiment_score.value', '', '=');
  
  $query->condition($or_group);
  $query->range(0, $batch_size);
  
  $nids = $query->execute();
  
  if (empty($nids)) {
    \Drupal::logger('news_extractor')->info('No articles found that need AI analysis regeneration.');
    return;
  }
  
  $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
  
  foreach ($nodes as $node) {
    try {
      $body_content = $node->get('body')->value;
      $title = $node->getTitle();
      
      if (empty($body_content) || strlen(strip_tags($body_content)) < 100) {
        continue;
      }
      
      // Generate new AI summary with updated prompt
      $ai_summary = _news_extractor_generate_ai_summary(strip_tags($body_content), $title);
      
      if ($ai_summary) {
        // Store raw AI summary
        if ($node->hasField('field_ai_summary')) {
          $node->set('field_ai_summary', $ai_summary);
        }
        
        // Extract and store structured data
        if ($node->hasField('field_motivation_data')) {
          $structured_data = _news_extractor_extract_structured_data($ai_summary);
          $node->set('field_motivation_data', json_encode($structured_data));
          
          // Populate individual fields
          if ($node->hasField('field_credibility_score') && !is_null($structured_data['credibility_score'])) {
            $node->set('field_credibility_score', (string)$structured_data['credibility_score']);
          }
          
          if ($node->hasField('field_bias_rating') && !is_null($structured_data['bias_rating'])) {
            $node->set('field_bias_rating', (string)$structured_data['bias_rating']);
          }
          
          if ($node->hasField('field_bias_analysis') && !empty($structured_data['bias_analysis'])) {
            $node->set('field_bias_analysis', implode("\n", $structured_data['bias_analysis']));
          }
          
          if ($node->hasField('field_article_sentiment_score') && !is_null($structured_data['sentiment_score'])) {
            $node->set('field_article_sentiment_score', (string)$structured_data['sentiment_score']);
          }
          
          // Create tags from new analysis
          $simple_tags = [];
          foreach ($structured_data['entities'] as $entity_data) {
            $simple_tags[] = $entity_data['name'];
            $simple_tags = array_merge($simple_tags, $entity_data['motivations']);
          }
          $simple_tags = array_merge($simple_tags, $structured_data['metrics']);
          
          // Create taxonomy terms
          $tag_ids = [];
          foreach (array_unique($simple_tags) as $tag) {
            if (!empty(trim($tag))) {
              $tid = _news_extractor_get_or_create_tag(trim($tag));
              if ($tid) $tag_ids[] = $tid;
            }
          }
          
          if (!empty($tag_ids) && $node->hasField('field_tags')) {
            $node->set('field_tags', $tag_ids);
          }
        }
        
        // Format motivation analysis for display
        $motivation_analysis = news_extractor_format_motivation_analysis($ai_summary);
        
        // Apply linkification if we have tags
        if (!empty($tag_ids)) {
          $tag_entities = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadMultiple($tag_ids);
          $motivation_analysis_linked = news_extractor_linkify_summary_tags_enhanced($motivation_analysis, $tag_entities);
          
          if ($node->hasField('field_motivation_analysis')) {
            $node->set('field_motivation_analysis', [
              'value' => $motivation_analysis_linked,
              'format' => 'basic_html',
            ]);
          }
        } else {
          if ($node->hasField('field_motivation_analysis')) {
            $node->set('field_motivation_analysis', [
              'value' => $motivation_analysis,
              'format' => 'basic_html',
            ]);
          }
        }
        
        $node->save();
        $processed++;
        
        \Drupal::logger('news_extractor')->info('Regenerated AI analysis for article @nid (@title)', [
          '@nid' => $node->id(),
          '@title' => $node->getTitle(),
        ]);
        
        // Add delay to avoid rate limiting
        sleep(2);
      }
      
    } catch (\Exception $e) {
      \Drupal::logger('news_extractor')->error('Error regenerating AI analysis for article @nid: @message', [
        '@nid' => $node->id(),
        '@message' => $e->getMessage(),
      ]);
    }
  }
  
  \Drupal::logger('news_extractor')->info('Regenerated AI analysis for @count articles. Run again if more articles need processing.', [
    '@count' => $processed,
  ]);
}
