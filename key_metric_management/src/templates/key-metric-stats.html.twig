{# modules/custom/key_metric_management/templates/key-metric-detail.html.twig #}
<h1>{{ 'Key Metric: @metric'|t({'@metric': metric}) }}</h1>
<div class="metric-count-display">
  <div class="count-number">{{ count }}</div>
  <div class="count-label">{{ 'articles reference this metric'|t }}</div>
</div>
<p><a href="{{ back_url }}">&larr; {{ 'Back to Dashboard'|t }}</a></p>

{# modules/custom/key_metric_management/templates/key-metric-stats.html.twig #}
{# Key metric statistics display #}
<h2>{{ 'Key Metric Statistics'|t }}</h2>
<div class="metric-stats-grid">
  <div class="stat-card">
    <strong>{{ 'Total Unique Metrics'|t }}</strong><br>
    <span class="stat-number">{{ stats.total_metrics }}</span>
  </div>
  <div class="stat-card">
    <strong>{{ 'Articles with Metrics'|t }}</strong><br>
    <span class="stat-number">{{ stats.total_articles_with_metrics }}</span>
  </div>
  <div class="stat-card">
    <strong>{{ 'Most Common Metric'|t }}</strong><br>
    <span class="stat-text">{{ stats.most_common_metric }}</span>
  </div>
</div>